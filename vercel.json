{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/price",
      "destination": "/pricing",
      "permanent": true
    },
    {
      "source": "/en/price",
      "destination": "/en/pricing",
      "permanent": true
    },
    {
      "source": "/ja/price",
      "destination": "/ja/pricing",
      "permanent": true
    },
    {
      "source": "/ko/price",
      "destination": "/ko/pricing",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/:path(login|register|dashboard|tokens|logs|tasks|topup|account)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/:lang(en|ja|ko)/:path(login|register|dashboard|tokens|logs|tasks|topup|account)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://apiroute.subrouter.ai/api/:path*"
    },
    {
      "source": "/v1/:path*",
      "destination": "https://apiroute.subrouter.ai/v1/:path*"
    },
    {
      "source": "/:path(login|register|dashboard|tokens|logs|tasks|topup|account)",
      "destination": "/index.html"
    },
    {
      "source": "/:lang(en|ja|ko)/:path(login|register|dashboard|tokens|logs|tasks|topup|account)",
      "destination": "/index.html"
    }
  ]
}
