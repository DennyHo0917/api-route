{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/price",
      "destination": "/pricing",
      "permanent": true
    },
    {
      "source": "/en/price",
      "destination": "/pricing",
      "permanent": true
    },
    {
      "source": "/zh/price",
      "destination": "/zh/pricing",
      "permanent": true
    },
    {
      "source": "/ja/price",
      "destination": "/ja/pricing",
      "permanent": true
    },
    {
      "source": "/ko/price",
      "destination": "/ko/pricing",
      "permanent": true
    },
    {
      "source": "/sub-site",
      "destination": "/ai-api-reseller-platform",
      "permanent": true
    },
    {
      "source": "/en/sub-site",
      "destination": "/ai-api-reseller-platform",
      "permanent": true
    },
    {
      "source": "/zh/sub-site",
      "destination": "/zh/ai-api-reseller-platform",
      "permanent": true
    },
    {
      "source": "/ja/sub-site",
      "destination": "/ja/ai-api-reseller-platform",
      "permanent": true
    },
    {
      "source": "/ko/sub-site",
      "destination": "/ko/ai-api-reseller-platform",
      "permanent": true
    },
    {
      "source": "/en",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/en/:path*",
      "destination": "/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/login",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/:lang/login",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/register",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/:lang/register",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/dashboard",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/:lang/dashboard",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/tokens",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/:lang/tokens",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/logs",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/:lang/logs",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/tasks",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/:lang/tasks",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/topup",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/:lang/topup",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/account",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/:lang/account",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://apiroute.subrouter.ai/api/:path*"
    },
    {
      "source": "/v1/:path*",
      "destination": "https://apiroute.subrouter.ai/v1/:path*"
    },
    {
      "source": "/login",
      "destination": "/"
    },
    {
      "source": "/:lang/login",
      "destination": "/"
    },
    {
      "source": "/register",
      "destination": "/"
    },
    {
      "source": "/:lang/register",
      "destination": "/"
    },
    {
      "source": "/dashboard",
      "destination": "/"
    },
    {
      "source": "/:lang/dashboard",
      "destination": "/"
    },
    {
      "source": "/tokens",
      "destination": "/"
    },
    {
      "source": "/:lang/tokens",
      "destination": "/"
    },
    {
      "source": "/logs",
      "destination": "/"
    },
    {
      "source": "/:lang/logs",
      "destination": "/"
    },
    {
      "source": "/tasks",
      "destination": "/"
    },
    {
      "source": "/:lang/tasks",
      "destination": "/"
    },
    {
      "source": "/topup",
      "destination": "/"
    },
    {
      "source": "/:lang/topup",
      "destination": "/"
    },
    {
      "source": "/account",
      "destination": "/"
    },
    {
      "source": "/:lang/account",
      "destination": "/"
    }
  ]
}
